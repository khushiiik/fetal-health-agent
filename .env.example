GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Values: "mock" | "bigquery"
DATA_SOURCE=mock

# ===== Path Variables =====
MOCK_DATA_PATH=data/mock
CLINICAL_DATA_PATH=data/clinical/reference_ranges.json

BIGQUERY_PROJECT_ID=your_bigquery_project_id
BIGQUERY_DATASET=your_bigquery_dataset
BIGQUERY_TABLE=your_bigquery_table

GOOGLE_CLOUD_PROJECT=your_google_cloud_project
GOOGLE_APPLICATION_CREDENTIALS=credentials/fetal-health-service.json

# Values: "development" | "staging" | "production"
APP_ENV=development

# ===== Logging Setup =====
# Log level for loguru
# Values: "DEBUG" | "INFO" | "WARNING" | "ERROR"
LOG_LEVEL=DEBUG

# Log output format
# Values: "text" | "json"
LOG_FORMAT=text

# ===== Agent Flow & Safety Limits =====
# Maximum number of tool call iterations per agent before forced stop
ADK_MAX_ITERATIONS=10

# Agent execution timeout in seconds
AGENT_TIMEOUT_SECONDS=60

# ===== Port Settings =====
STREAMLIT_PORT=8501